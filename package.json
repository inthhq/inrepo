{
  "name": "inrepo",
  "version": "0.0.1",
  "description": "Vendor upstream git repositories into inrepo_modules from declarative config",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inthhq/inrepo.git"
  },
  "homepage": "https://github.com/inthhq/inrepo#readme",
  "bugs": {
    "url": "https://github.com/inthhq/inrepo/issues"
  },
  "bin": {
    "inrepo": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "packageManager": "bun@1.3.12",
  "scripts": {
    "build": "rolldown -c rolldown.config.ts",
    "dev": "rolldown -c rolldown.config.ts --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.3"
  },
  "packages": {
    "c15t": "file:inrepo_modules/c15t"
  },
  "keywords": [
    "vendor",
    "git",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.19.17",
    "rolldown": "^1.0.0-rc.16",
    "typescript": "^6.0.3"
  }
}
