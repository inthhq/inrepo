{
  "name": "inrepo",
  "version": "0.0.2",
  "description": "Vendor upstream git repositories into inrepo_modules from declarative config",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inthhq/inrepo.git"
  },
  "homepage": "https://github.com/inthhq/inrepo#readme",
  "bugs": {
    "url": "https://github.com/inthhq/inrepo/issues"
  },
  "bin": {
    "inrepo": "dist/cli.mjs"
  },
  "files": [
    "dist",
    "inrepo.schema.json"
  ],
  "packageManager": "bun@1.3.12",
  "scripts": {
    "build": "rolldown -c rolldown.config.ts",
    "changeset": "changeset",
    "ci:publish": "bunx changeset tag && bun publish",
    "ci:version": "changeset version",
    "dev": "rolldown -c rolldown.config.ts --watch",
    "release": "bun run build && changeset publish",
    "typecheck": "tsc --noEmit",
    "test": "bun test ./src",
    "test:watch": "bun test --watch ./src",
    "version": "changeset version && bun install",
    "prepublishOnly": "bun run build"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.3"
  },
  "keywords": [
    "vendor",
    "git",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^22.19.17",
    "@types/safe-regex": "^1.1.6",
    "rolldown": "^1.0.0-rc.17",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "safe-regex": "^2.1.1"
  }
}
